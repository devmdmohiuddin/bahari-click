# ─────────────────────────────────────────────────────────────
# Bahari Click — environment variables
# Copy to `.env` and fill in. NEVER commit `.env`.
# Dev goal: everything runs at ৳0 — paid services are mocked.
# See docs/06-cost-and-free-tiers.md
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
NODE_ENV="development"
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Database (local Postgres via Docker in dev) ──────────────
# Matches docker-compose.yml. Swap for Neon/Supabase at launch.
DATABASE_URL="postgresql://bahari:bahari@localhost:5433/bahari_click?schema=public"

# ── Auth (Better Auth) ───────────────────────────────────────
# Generate a strong secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET="dev-secret-change-me-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# ── SMS provider ─────────────────────────────────────────────
# "mock" logs OTP/messages to the server console (free dev mode).
# Switch to a real provider (bulksmsbd / alpha) at launch.
SMS_PROVIDER="mock"
SMS_API_KEY=""
SMS_SENDER_ID=""

# ── Courier provider ─────────────────────────────────────────
# "mock" returns canned fraud-check / consignment responses.
COURIER_PROVIDER="mock"
STEADFAST_API_KEY=""
STEADFAST_SECRET_KEY=""
STEADFAST_BASE_URL="https://portal.steadfast.com.bd/api/v1"

# ── Cloudinary (image CDN, free tier) ────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_FOLDER="bahari-click/dev"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# ── Sentry (error monitoring, free tier — optional) ──────────
# Leave empty in dev; Sentry init becomes a no-op without a DSN.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"

# ── Background jobs / cron ───────────────────────────────────
# Vercel Cron must send `Authorization: Bearer <CRON_SECRET>`.
# Leave empty in dev to keep /api/cron/sync open locally.
CRON_SECRET=""

# ── Webhooks ─────────────────────────────────────────────────
# HMAC-SHA256 secret for the inbound courier status webhook
# (/api/webhooks/courier). Empty disables the endpoint (503).
COURIER_WEBHOOK_SECRET=""

# ── Analytics (optional) ─────────────────────────────────────
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_META_PIXEL_ID=""
META_CAPI_ACCESS_TOKEN=""
