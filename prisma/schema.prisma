// Bahari Click — Prisma schema.
// Money is Int (whole BDT). Times are UTC. See docs/04-data-model.md.
// Phase 0 scope: auth (Better Auth) + audit log. Catalog/order tables land in Phase 1+.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  // Prisma 7: connection URL lives in prisma.config.ts (CLI) and the driver
  // adapter passed to PrismaClient at runtime (see src/lib/db.ts).
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────────────────────
// Unified identity table for both admins (email/password + role) and customers
// (phone + OTP). Managed by Better Auth; see src/lib/auth.ts.

enum UserRole {
  OWNER
  MANAGER
  STAFF
  CUSTOMER
}

model User {
  id            String  @id
  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  image         String?

  // admin plugin
  role       UserRole  @default(CUSTOMER)
  banned     Boolean   @default(false)
  banReason  String?
  banExpires DateTime?

  // phoneNumber plugin (BD customers — primary identity)
  phoneNumber         String?  @unique
  phoneNumberVerified Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions  Session[]
  accounts  Account[]
  auditLogs AuditLog[]
  reviews   Review[]

  @@index([role])
  @@map("user")
}

model Session {
  id        String   @id
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?

  // admin plugin: impersonation
  impersonatedBy String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ─── Audit log ───────────────────────────────────────────────────────────────
// Records admin mutations on orders/stock and other sensitive entities.

model AuditLog {
  id       String  @id @default(cuid())
  adminId  String?
  admin    User?   @relation(fields: [adminId], references: [id], onDelete: SetNull)
  action   String // e.g. "order.status_change"
  entity   String // e.g. "Order"
  entityId String?
  diff     Json?

  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([adminId])
  @@map("audit_log")
}

// ─── Catalog ─────────────────────────────────────────────────────────────────
// Category → Subcategory → Product → Variant. Images link to a product (shared
// gallery) and/or a variant (drives the variant-switch image). See docs/04-data-model.md.

model Category {
  id        String  @id @default(cuid())
  name      String
  slug      String  @unique
  image     String?
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subcategories Subcategory[]

  @@index([isActive, sortOrder])
  @@map("category")
}

model Subcategory {
  id         String  @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name       String
  slug       String  @unique
  image      String?
  sortOrder  Int     @default(0)
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([categoryId, isActive, sortOrder])
  @@map("subcategory")
}

model Product {
  id            String  @id @default(cuid())
  title         String
  slug          String  @unique
  subcategoryId String
  subcategory   Subcategory @relation(fields: [subcategoryId], references: [id], onDelete: Restrict)

  description    String  @default("") @db.Text // rich text
  basePrice      Int // whole BDT; a variant may override
  compareAtPrice Int? // strikethrough

  soldCountReal  Int @default(0) // incremented on delivered orders
  soldCountBoost Int @default(0) // manual social-proof offset
  // display sold = soldCountReal + soldCountBoost

  isPublished Boolean @default(false)
  isFeatured  Boolean @default(false)

  ratingAvg   Float @default(0) // denormalized from approved reviews
  ratingCount Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants Variant[]
  images   ProductImage[]
  specs    Specification[]
  reviews  Review[]

  @@index([subcategoryId, isPublished])
  @@index([isPublished, isFeatured])
  @@index([isPublished, createdAt])
  @@index([title])
  @@map("product")
}

model Variant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  sku      String  @unique
  color    String?
  size     String?
  price    Int? // null → use Product.basePrice
  stock    Int     @default(0)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images VariantImage[]

  @@unique([productId, color, size])
  @@index([productId])
  @@map("variant")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String // Cloudinary URL/public id
  alt       String?
  sortOrder Int     @default(0)

  @@index([productId, sortOrder])
  @@map("product_image")
}

model VariantImage {
  id        String  @id @default(cuid())
  variantId String
  variant   Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int     @default(0)

  @@index([variantId, sortOrder])
  @@map("variant_image")
}

model Specification {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  key       String // "Material"
  value     String // "PU Leather"
  sortOrder Int     @default(0)

  @@index([productId, sortOrder])
  @@map("specification")
}

// ─── Reviews ─────────────────────────────────────────────────────────────────
// Customer or guest reviews. Created hidden (isApproved=false) and surfaced only
// after moderation. Product.ratingAvg/ratingCount are recomputed on approve/delete.

model Review {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  customerId String?
  customer   User?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  guestName  String? // used when there is no linked customer

  rating    Int // 1..5
  comment   String?  @db.Text
  imageUrls String[] @default([])

  isApproved Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([productId, isApproved])
  @@map("review")
}

// ─── Rate limiting ───────────────────────────────────────────────────────────
// Postgres-backed fixed-window limiter (no Upstash needed in dev/launch — see
// docs/06-cost-and-free-tiers.md). One row per key; window resets on expiry.

model RateLimit {
  key     String   @id // e.g. "review:create:<ip>"
  count   Int      @default(0)
  resetAt DateTime

  @@map("rate_limit")
}
