// Bahari Click — Prisma schema.
// Money is Int (whole BDT). Times are UTC. See docs/04-data-model.md.
// Phase 0 scope: auth (Better Auth) + audit log. Catalog/order tables land in Phase 1+.

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  // Prisma 7: connection URL lives in prisma.config.ts (CLI) and the driver
  // adapter passed to PrismaClient at runtime (see src/lib/db.ts).
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────────────────────
// Unified identity table for both admins (email/password + role) and customers
// (phone + OTP). Managed by Better Auth; see src/lib/auth.ts.

enum UserRole {
  OWNER
  MANAGER
  STAFF
  CUSTOMER
}

model User {
  id            String  @id
  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  image         String?

  // admin plugin
  role       UserRole  @default(CUSTOMER)
  banned     Boolean   @default(false)
  banReason  String?
  banExpires DateTime?

  // phoneNumber plugin (BD customers — primary identity)
  phoneNumber         String?  @unique
  phoneNumberVerified Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions           Session[]
  accounts           Account[]
  auditLogs          AuditLog[]
  reviews            Review[]
  stockAdjustments   StockAdjustment[]
  orders             Order[]
  orderStatusChanges OrderStatusHistory[]
  addresses          Address[]
  wishlist           Wishlist[]

  @@index([role])
  @@map("user")
}

model Session {
  id        String   @id
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?

  // admin plugin: impersonation
  impersonatedBy String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ─── Audit log ───────────────────────────────────────────────────────────────
// Records admin mutations on orders/stock and other sensitive entities.

model AuditLog {
  id       String  @id @default(cuid())
  adminId  String?
  admin    User?   @relation(fields: [adminId], references: [id], onDelete: SetNull)
  action   String // e.g. "order.status_change"
  entity   String // e.g. "Order"
  entityId String?
  diff     Json?

  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([adminId])
  @@map("audit_log")
}

// ─── Catalog ─────────────────────────────────────────────────────────────────
// Category → Subcategory → Product → Variant. Images link to a product (shared
// gallery) and/or a variant (drives the variant-switch image). See docs/04-data-model.md.

model Category {
  id        String  @id @default(cuid())
  name      String
  slug      String  @unique
  image     String?
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subcategories Subcategory[]

  @@index([isActive, sortOrder])
  @@map("category")
}

model Subcategory {
  id         String  @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name       String
  slug       String  @unique
  image      String?
  sortOrder  Int     @default(0)
  isActive   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@index([categoryId, isActive, sortOrder])
  @@map("subcategory")
}

model Product {
  id            String  @id @default(cuid())
  title         String
  slug          String  @unique
  subcategoryId String
  subcategory   Subcategory @relation(fields: [subcategoryId], references: [id], onDelete: Restrict)

  description    String  @default("") @db.Text // rich text
  basePrice      Int // whole BDT; a variant may override
  compareAtPrice Int? // strikethrough

  soldCountReal  Int @default(0) // incremented on delivered orders
  soldCountBoost Int @default(0) // manual social-proof offset
  // display sold = soldCountReal + soldCountBoost

  isPublished Boolean @default(false)
  isFeatured  Boolean @default(false)

  ratingAvg   Float @default(0) // denormalized from approved reviews
  ratingCount Int   @default(0)

  // AI-2: cached review summary { sentiment, pros[], cons[] } + when generated.
  // Regenerated as approved reviews accumulate; null until first generation.
  reviewSummary   Json?
  reviewSummaryAt DateTime?

  // AI-5: AI-drafted SEO meta (admin reviews/edits; falls back to title/desc).
  seoTitle       String?
  seoDescription String?

  // AI-3 / AI-6: cached embedding vector (number[]) for semantic search +
  // recommendations. In-app cosine similarity — no pgvector needed (free tier).
  embedding Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants        Variant[]
  images          ProductImage[]
  specs           Specification[]
  reviews         Review[]
  preOrders       PreOrderRequest[]
  wishlistedBy    Wishlist[]
  sourcingRecords SourcingRecord[]

  @@index([subcategoryId, isPublished])
  @@index([isPublished, isFeatured])
  @@index([isPublished, createdAt])
  @@index([title])
  @@map("product")
}

model Variant {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  sku      String  @unique
  color    String?
  size     String?
  price    Int? // null → use Product.basePrice
  stock    Int     @default(0)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images      VariantImage[]
  adjustments StockAdjustment[]
  preOrders   PreOrderRequest[]
  orderItems  OrderItem[]

  @@unique([productId, color, size])
  @@index([productId])
  @@index([stock])
  @@map("variant")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String // Cloudinary URL/public id
  alt       String?
  sortOrder Int     @default(0)

  @@index([productId, sortOrder])
  @@map("product_image")
}

model VariantImage {
  id        String  @id @default(cuid())
  variantId String
  variant   Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  sortOrder Int     @default(0)

  @@index([variantId, sortOrder])
  @@map("variant_image")
}

model Specification {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  key       String // "Material"
  value     String // "PU Leather"
  sortOrder Int     @default(0)

  @@index([productId, sortOrder])
  @@map("specification")
}

// ─── Reviews ─────────────────────────────────────────────────────────────────
// Customer or guest reviews. Created hidden (isApproved=false) and surfaced only
// after moderation. Product.ratingAvg/ratingCount are recomputed on approve/delete.

model Review {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  customerId String?
  customer   User?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  guestName  String? // used when there is no linked customer

  rating    Int // 1..5
  comment   String?  @db.Text
  imageUrls String[] @default([])

  isApproved Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([productId, isApproved])
  @@map("review")
}

// ─── Rate limiting ───────────────────────────────────────────────────────────
// Postgres-backed fixed-window limiter (no Upstash needed in dev/launch — see
// docs/06-cost-and-free-tiers.md). One row per key; window resets on expiry.

model SmsLog {
  id                String  @id @default(cuid())
  to                String
  template          String
  text              String
  provider          String
  ok                Boolean
  providerMessageId String?
  error             String?

  createdAt DateTime @default(now())

  @@index([to, createdAt])
  @@map("sms_log")
}

// ─── Contact messages ────────────────────────────────────────────────────────
// Storefront contact-form submissions (support/enquiries). Read in the admin
// inbox. Powers storefront S6.4 and admin A6.4.

model ContactMessage {
  id      String  @id @default(cuid())
  name    String
  phone   String // +8801XXXXXXXXX
  email   String?
  subject String
  message String  @db.Text
  isRead  Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([isRead, createdAt])
  @@map("contact_message")
}

// ─── Payments [post-launch] ──────────────────────────────────────────────────
// Online payments via SSLCommerz (sandbox in dev). COD needs no Payment row;
// this supports advance-charge / fully-prepaid online orders. See docs/02-tech-stack.md.

model Payment {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  provider      String // "sslcommerz" | "mock"
  transactionId String        @unique // our tran_id sent to the gateway
  amount        Int // whole BDT
  status        PaymentStatus @default(pending)

  gatewayValId    String? // val_id returned by SSLCommerz
  gatewaySessionId String?
  cardType        String?
  raw             Json? // last gateway payload, for audit/debugging

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([status])
  @@map("payment")
}

// ─── Accounts [post-launch] ──────────────────────────────────────────────────
// Saved addresses + wishlist for logged-in customers. Order history is a query
// on Order.customerId (no new table).

model Address {
  id         String @id @default(cuid())
  customerId String
  customer   User   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  name      String
  phone     String
  line1     String
  area      String?
  city      String?
  zoneId    String?
  zone      ShippingZone? @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  note      String?
  isDefault Boolean       @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@map("address")
}

model Wishlist {
  id         String  @id @default(cuid())
  customerId String
  customer   User    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([customerId, productId])
  @@index([customerId])
  @@map("wishlist")
}

// ─── Returns [post-launch] ───────────────────────────────────────────────────
// Return request against a delivered order. On completion the order moves to
// `returned` (stock restocked), soldCountReal is decremented, and any online
// payment is marked refunded.

enum ReturnStatus {
  requested
  approved
  rejected
  completed
}

model Return {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  reason       String
  status       ReturnStatus @default(requested)
  refundAmount Int?
  note         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([status])
  @@map("return")
}

// ─── Sourcing & margin [post-launch] ─────────────────────────────────────────
// China-sourcing purchase records for landed-cost / profit analytics. Costs are
// whole units: unitCostCNY in CNY, shippingCost + landedCostBDT in BDT.

model SourcingRecord {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  supplierName String
  supplierUrl  String?
  unitCostCNY  Int // per-unit supplier cost in CNY
  shippingCost Int // batch shipping in BDT
  batchQty     Int
  landedCostBDT Int // computed per-unit landed cost in BDT

  purchasedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([productId, purchasedAt])
  @@map("sourcing_record")
}

// ─── Campaigns [post-launch] ─────────────────────────────────────────────────
// Flash sales / landing pages. `config` holds type-specific payload (product
// ids + discount for flash, section blocks for landing).

enum CampaignType {
  flash
  landing
}

model Campaign {
  id       String       @id @default(cuid())
  title    String
  slug     String       @unique
  type     CampaignType
  startsAt DateTime?
  endsAt   DateTime?
  isActive Boolean      @default(true)
  config   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, isActive])
  @@map("campaign")
}

model RateLimit {
  key     String   @id // e.g. "review:create:<ip>"
  count   Int      @default(0)
  resetAt DateTime

  @@map("rate_limit")
}

// ─── Stock ───────────────────────────────────────────────────────────────────
// Variant.stock is authoritative. Every change is recorded here with a reason
// so stock movements are auditable (manual edits, restocks, order decrements).

model StockAdjustment {
  id        String  @id @default(cuid())
  variantId String
  variant   Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  delta    Int // signed change applied
  newStock Int // resulting stock after the change
  reason   String // e.g. "manual", "restock", "order:BC-...", "cancel"

  adminId String?
  admin   User?   @relation(fields: [adminId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([variantId, createdAt])
  @@map("stock_adjustment")
}

// ─── Pre-order / notify-me ───────────────────────────────────────────────────
// A buyer asks to be notified when an out-of-stock variant returns. On restock
// the request is marked `notified` and a NotifyJob is enqueued (SMS send lands
// in Phase 5; the job table is the queue stub until then).

enum PreOrderStatus {
  pending
  notified
  fulfilled
  cancelled
}

model PreOrderRequest {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?
  variant   Variant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  phone String // +8801XXXXXXXXX
  name  String?
  qty   Int    @default(1)

  status     PreOrderStatus @default(pending)
  createdAt  DateTime       @default(now())
  notifiedAt DateTime?

  @@index([productId, status])
  @@index([variantId, status])
  @@map("pre_order_request")
}

// ─── Background jobs (DB-backed queue) ───────────────────────────────────────
// Free dev/launch queue (docs/06-cost-and-free-tiers.md). A Vercel Cron worker
// drains this in Phase 5; for now restock notifications are just enqueued here.

enum JobStatus {
  pending
  processing
  done
  failed
}

model NotifyJob {
  id        String    @id @default(cuid())
  type      String // e.g. "preorder_restock"
  payload   Json
  status    JobStatus @default(pending)
  attempts  Int       @default(0)
  runAt     DateTime  @default(now())
  lastError String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, runAt])
  @@map("notify_job")
}

// ─── Shipping zones [BD] ─────────────────────────────────────────────────────
// Flat per-zone COD delivery fee (e.g. Inside Dhaka / Sub-Dhaka / Outside Dhaka).
// Optional free-ship threshold waives the fee above a subtotal. See docs/05-bd-market.md.

model ShippingZone {
  id                String  @id @default(cuid())
  name              String
  fee               Int // whole BDT
  freeShipThreshold Int? // subtotal at/above which fee is waived
  isActive          Boolean @default(true)
  sortOrder         Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  addresses Address[]

  @@index([isActive, sortOrder])
  @@map("shipping_zone")
}

// ─── Coupons ─────────────────────────────────────────────────────────────────
// Percent or fixed-amount discount with optional window, min-order, usage limit,
// and max-discount cap. usedCount is incremented under a guard at order time.

enum CouponType {
  percent
  fixed
}

model Coupon {
  id          String     @id @default(cuid())
  code        String     @unique // stored uppercase
  type        CouponType
  value       Int // percent 0..100, or fixed whole BDT
  minOrder    Int? // minimum subtotal to qualify
  maxDiscount Int? // cap for percent coupons
  usageLimit  Int? // null = unlimited
  usedCount   Int        @default(0)
  startsAt    DateTime?
  endsAt      DateTime?
  isActive    Boolean    @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@index([isActive])
  @@map("coupon")
}

// ─── Orders ──────────────────────────────────────────────────────────────────
// COD-only at launch. Money/stock are recomputed server-side at placement; unit
// prices and the delivery address are snapshotted so later edits don't rewrite
// history. See docs/03-architecture.md (Checkout flow) and docs/04-data-model.md.

enum OrderStatus {
  pending
  confirmed
  packed
  dispatched
  delivered
  returned
  cancelled
}

enum PaymentMethod {
  COD
  SSLCOMMERZ
}

enum PaymentStatus {
  pending
  success
  failed
  cancelled
  refunded
}

model Order {
  id          String @id @default(cuid())
  orderNumber String @unique // e.g. BC-26171-0042

  customerId String?
  customer   User?   @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // Address snapshot (independent of any mutable Address row).
  custName    String
  custPhone   String
  custAddress String
  custArea    String?
  custCity    String?

  zoneId      String
  zone        ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Restrict)
  shippingFee Int

  subtotal Int
  discount Int @default(0)
  total    Int

  couponId String?
  coupon   Coupon? @relation(fields: [couponId], references: [id], onDelete: SetNull)

  paymentMethod PaymentMethod @default(COD)
  status        OrderStatus   @default(pending)

  fraudScore   Int?
  fraudVerdict String?

  courierName  String?
  trackingCode String?
  internalNote String?
  metaEventId  String? // FB CAPI dedup

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  payments      Payment[]
  returns       Return[]

  @@index([status])
  @@index([custPhone])
  @@index([createdAt])
  @@map("order")
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  variantId String?
  variant   Variant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  // Snapshots for history (survive product/variant edits or deletes).
  productTitle String
  variantLabel String
  unitPrice    Int
  qty          Int
  lineTotal    Int

  @@index([orderId])
  @@map("order_item")
}

model OrderStatusHistory {
  id      String      @id @default(cuid())
  orderId String
  order   Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status  OrderStatus
  note    String?

  changedByAdminId String?
  changedByAdmin   User?   @relation(fields: [changedByAdminId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
  @@map("order_status_history")
}
